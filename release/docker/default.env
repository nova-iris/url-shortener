# URL Shortener Application Configuration
# Copy this file to .env in the release directory and modify as needed

# Node.js environment: development, production, test
NODE_ENV=production

# Server port
PORT=5000

# MongoDB credentials
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=IcKeW8b5wxMixE7ByYMkkJ1389/+he4cL7UHi9iEoZc=

# MongoDB host - for docker compose this is the service name
MONGODB_HOST=mongo

# MongoDB port - default is 27017
MONGODB_PORT=27017

# MongoDB database name
MONGODB_DATABASE=urlshortener

# Base URL for generating shortened URLs
BASEURI=http://localhost:5000

# Client configuration
CLIENT_URL=http://localhost:4173